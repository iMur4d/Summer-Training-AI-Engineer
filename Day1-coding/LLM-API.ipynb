    "import os\n",
    "from dotenv import load_dotenv\n",
    "\n",
    "load_dotenv()\n",
    "\n",
    "my_variable = os.getenv(\"TEST_KEY\")\n",
    "\n",
    "if my_variable:\n",
    "    print(f\"Value: {my_variable}\")\n",
    "else:\n",
    "    print(\"❌ Failed to read the file. Please check the path of the .env file and save the changes.\")"
   ]
  }
